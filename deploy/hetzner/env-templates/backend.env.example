# Backend production env — copy to /etc/autobids/backend.env on ab-back1.
# Mode 600, owned by www-data. NEVER commit a filled-in copy to git.

# ── Database ────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=autobids
# NOTE: the `+asyncpg` driver prefix is REQUIRED — SQLAlchemy uses the async
# asyncpg driver for the bidding subsystem. A plain `postgresql://` URL will
# fail at boot with "Can't load plugin: sqlalchemy.dialects:postgresql.async".
POSTGRES_URL=postgresql+asyncpg://autobid_user:CHANGE_ME@localhost:5432/autobid

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_HEX_CHARS

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys — use the LIVE key in prod.
STRIPE_API_KEY=sk_live_CHANGE_ME
# Get from https://dashboard.stripe.com/webhooks after creating the webhook
# pointing to https://autoandbid.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_SUCCESS_URL=https://autoandbid.com/dashboard/payments?status=success
STRIPE_CANCEL_URL=https://autoandbid.com/dashboard/payments?status=cancelled

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME
SENDER_EMAIL=noreply@autoandbid.com

# ── SMS (Twilio) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC_CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+359xxxxxxxxx

# ── Public URLs ─────────────────────────────────────────────────────────────
# Three brand domains share the same backend. Auto-language by hostname:
#   autoandbid.com → English  (default for international visitors)
#   autoandbid.bg  → Bulgarian
#   autoandbid.ro  → Romanian
FRONTEND_URL=https://autoandbid.com
APP_URL=https://autoandbid.com
ALLOWED_ORIGINS=https://autoandbid.com,https://www.autoandbid.com,https://autoandbid.bg,https://www.autoandbid.bg,https://autoandbid.ro,https://www.autoandbid.ro
CORS_ORIGINS=https://autoandbid.com,https://www.autoandbid.com,https://autoandbid.bg,https://www.autoandbid.bg,https://autoandbid.ro,https://www.autoandbid.ro

# ── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_CONTACT_EMAIL=mailto:contact@autoandbid.com

# ── AI translations (Hetzner-direct, NOT Emergent Universal Key) ────────────
# Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_CHANGE_ME

# ── Optional: initial admin seed (only used on a fresh DB) ──────────────────
ADMIN_EMAIL=admin@autoandbid.com
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Runtime tuning ──────────────────────────────────────────────────────────
WORKERS=2
LOG_LEVEL=info
