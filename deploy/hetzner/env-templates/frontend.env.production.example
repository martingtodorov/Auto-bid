# Frontend build-time env — copy to frontend/.env.production before `yarn build`.
# Read by Create React App at build time only; baked into the static bundle.

# Same backend serves all three brand domains. Use `autoandbid.com` so the
# bundle works identically on any of them (the frontend uses relative /api/*
# paths via this base URL, and Cloudflare/nginx proxy stays on the same host).
REACT_APP_BACKEND_URL=https://autoandbid.com

# Domain → language mapping. Frontend reads window.location.hostname and
# auto-applies the matching language. Users can still switch via the UI
# (choice persisted in localStorage); the next visit on the matching TLD
# wins again unless they manually override.
REACT_APP_DOMAIN_BG=autoandbid.bg
REACT_APP_DOMAIN_RO=autoandbid.ro
REACT_APP_DOMAIN_EN=autoandbid.com

# Cookie banner respects this — disables the maintenance health-check probe in prod.
ENABLE_HEALTH_CHECK=false
