###############################################################################
# autobids-backend.service — FastAPI + uvicorn under systemd on ab-back1
#
# Install:
#   sudo cp autobids-backend.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now autobids-backend
#
# View logs:    journalctl -fu autobids-backend
# Reload code:  sudo systemctl restart autobids-backend
###############################################################################
[Unit]
Description=Auto&Bid backend (FastAPI / uvicorn)
After=network-online.target mongod.service postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data

# Code lives at /opt/autobids/backend (deployed by ansible).
WorkingDirectory=/opt/autobids/backend
EnvironmentFile=/etc/autobids/backend.env

# Listen on 0.0.0.0 so nginx on ab-front1 can reach this process over the
# private LAN (10.0.0.3:8001). The Hetzner firewall keeps port 8001 closed
# to the public internet — only 10.0.0.0/16 is allowed by UFW (see the
# backend role). Do NOT change this to 127.0.0.1 unless the frontend is
# co-located on the same host.
ExecStart=/opt/autobids/venv/bin/uvicorn server:app \
    --host 0.0.0.0 \
    --port 8001 \
    --workers ${WORKERS} \
    --proxy-headers \
    --forwarded-allow-ips=10.0.0.0/16,127.0.0.1 \
    --log-level ${LOG_LEVEL} \
    --no-access-log

Restart=on-failure
RestartSec=5s
TimeoutStopSec=20s

# Security hardening (defense in depth)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/autobids /var/lib/autobids /var/backups/autobids /opt/autobids

# Resource limits
LimitNOFILE=65536
MemoryHigh=2G
MemoryMax=3G

[Install]
WantedBy=multi-user.target
